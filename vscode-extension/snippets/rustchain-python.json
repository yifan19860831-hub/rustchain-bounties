  "RustChain: Get epoch info": {
    "prefix": "rtc-epoch",
    "body": [
      "import requests",
      "",
      "NODE_URL = \"${1:https://50.28.86.131}\"",
      "",
      "resp = requests.get(f\"{NODE_URL}/epoch\", verify=False, timeout=${2:10})",
      "resp.raise_for_status()",
