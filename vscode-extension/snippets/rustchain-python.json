      "print(f\"Epoch: {epoch['epoch']}, slot: {epoch['slot']}, miners: {epoch['enrolled_miners']}\")"
    ],
    "description": "Fetch current epoch and slot info from the RustChain node."
  },
  "RustChain: List active miners": {
    "prefix": "rtc-miners",
    "body": [
      "import requests",
      "",
      "NODE_URL = \"${1:https://50.28.86.131}\"",
      "",
      "resp = requests.get(f\"{NODE_URL}/api/miners\", verify=False, timeout=${2:10})",
      "resp.raise_for_status()",
      "miners = resp.json()",
      "for m in miners:",
      "    print(f\"{m['miner']}  multiplier={m.get('antiquity_multiplier', '?')}\")"
    ],
    "description": "List all active RustChain miners."
  },
