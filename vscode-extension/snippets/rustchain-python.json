{
  "RustChain: Check wallet balance": {
    "prefix": "rtc-balance",
    "body": [
      "import requests",
      "",
      "NODE_URL = \"${1:https://50.28.86.131}\"",
      "MINER_ID = \"${2:my-miner-id}\"",
      "",
      "resp = requests.get(",
      "    f\"{NODE_URL}/wallet/balance\",",
      "    params={\"miner_id\": MINER_ID},",
      "    verify=False,",
      "    timeout=${3:10},",
      ")",
      "resp.raise_for_status()",
      "balance = resp.json()",
      "print(f\"Balance: {balance['amount_rtc']} RTC\")"
    ],
    "description": "Fetch RTC wallet balance from the RustChain node."
  },
  "RustChain: Check node health": {
    "prefix": "rtc-health",
    "body": [
      "import requests",
      "",
      "NODE_URL = \"${1:https://50.28.86.131}\"",
      "",
      "resp = requests.get(f\"{NODE_URL}/health\", verify=False, timeout=${2:10})",
