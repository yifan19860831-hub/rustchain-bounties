  "RustChain: Epoch enrollment": {
    "prefix": "rtc-enroll",
    "body": [
      "import requests",
      "",
      "NODE_URL = \"${1:https://50.28.86.131}\"",
      "MINER_ID = \"${2:my-miner-id}\"",
      "",
      "resp = requests.post(",
      "    f\"{NODE_URL}/epoch/enroll\",",
      "    json={",
      "        \"miner_pubkey\": \"${3:RTC_WALLET_ADDRESS}\",",
      "        \"miner_id\": MINER_ID,",
      "        \"device\": {\"family\": \"${4:x86_64}\", \"arch\": \"${5:modern}\"},",
      "    },",
      "    verify=False,",
      "    timeout=10,",
      ")",
      "print(resp.json())"
