{
  "manifest_version": 3,
  "name": "RustChain Wallet",
  "version": "1.0.0",
  "description": "Official RustChain (RTC) wallet browser extension. Manage your RTC tokens, send/receive payments, and view transaction history.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://50.28.86.131/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "RustChain Wallet"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
